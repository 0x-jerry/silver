{
  "editor.formatOnSave": true,
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always"
  },
  "ohm-js.validator": [
    {
      "grammar": "src/grammar/syntax.ohm",
      "match": [
        "**/*.cli"
      ]
    }
  ]
}
